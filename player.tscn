[sub_resource type="GDScript" id="GDScript_pbfsw"]
script/source = "extends CharacterBody2D

# --- CONFIGURACIÓN DE PARÁMETROS FÍSICOS ---
const SPEED = 300.0
const JUMP_VELOCITY = -400.0

# --- ESTADO DEL PERSONAJE ---
var attacking = false

# --- INICIALIZACIÓN DE INSTANCIA ---
func _ready() -> void:
	# Registro del nodo en el grupo \"player\" para la gestión de colisiones y eventos globales
	add_to_group(\"player\")

# --- CICLO DE PROCESAMIENTO FÍSICO (60 FPS) ---
func _physics_process(delta: float) -> void:
	
	# 1. GESTIÓN DE GRAVEDAD
	# Aplica la constante de gravedad del proyecto cuando el nodo no detecta superficie inferior
	if not is_on_floor():
		velocity += get_gravity() * delta

	# 2. CONTROL DE ORIENTACIÓN (INPUT)
	# Determina la dirección mediante el eje horizontal; restringido durante la ejecución de ataque
	var direction := Input.get_axis(\"ui_left\", \"ui_right\")
	if not attacking:
		if direction > 0:
			$AnimatedSprite2D.flip_h = false
		elif direction < 0:
			$AnimatedSprite2D.flip_h = true

	# 3. LÓGICA DE COMBATE (INPUT)
	# Activación del estado de ataque condicionado a estar en superficie estable (Grounded)
	if Input.is_action_just_pressed(\"Attack\") and is_on_floor() and not attacking:
		attacking = true
		
		# Ajuste de offset vertical del Sprite para alinear la animación de ataque con el CollisionShape
		$AnimatedSprite2D.offset.y = -4 
		$AnimatedSprite2D.play(\"Atacar\")

	# 4. RESTRICCIÓN DE MOVIMIENTO POR ATAQUE
	# Interrumpe la inercia horizontal durante la ejecución de la animación de combate
	if attacking:
		velocity.x = 0
		move_and_slide()
		return

	# 5. GESTIÓN DE SALTO Y DESPLAZAMIENTO HORIZONTAL
	# Ejecución de impulso vertical (Jump) y cálculo de velocidad lineal mediante interpolación
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = JUMP_VELOCITY

	if direction:
		velocity.x = direction * SPEED
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED)

	# 6. MÁQUINA DE ESTADOS DE ANIMACIÓN
	# Selección dinámica de clips basada en el vector de velocidad y estado de contacto con el suelo
	if is_on_floor():
		if direction != 0:
			$AnimatedSprite2D.play(\"Run\")
		else:
			$AnimatedSprite2D.play(\"Idle\")
	else:
		if velocity.y < 0:
			$AnimatedSprite2D.play(\"Jump\")
		else:
			$AnimatedSprite2D.play(\"Fall\")

	# Ejecución final del cálculo cinemático
	move_and_slide()

# --- GESTIÓN DE SEÑALES DE ANIMACIÓN ---
func _on_animated_sprite_2d_animation_finished() -> void:
	# Restablece el estado de movilidad y el offset del Sprite tras completar el ciclo de ataque
	if $AnimatedSprite2D.animation == \"Atacar\":
		attacking = false
		$AnimatedSprite2D.offset.y = 0
"

